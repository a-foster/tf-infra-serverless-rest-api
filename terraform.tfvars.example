# Example Terraform Variables
# Copy this file to terraform.tfvars and update with your values

# Core Configuration (Required)
aws_region           = "us-east-1"
environment          = "dev"
project_name         = "sano-interview"
lambda_function_name = "hello-world-api"
lambda_memory_size   = 512
lambda_timeout       = 30
api_stage_name       = "prod"

# GitHub Actions CI/CD Configuration (Optional)
# Leave github_org empty ("") to deploy infrastructure without GitHub Actions setup
# You can manually push images to ECR and update Lambda without CI/CD
# Uncomment and fill in to enable GitHub Actions OIDC integration:

# github_org        = "your-github-username"
# github_repo_infra = "tf-infra-serverless-rest-api"
# github_repo_app   = "hello-world-app"
